@model List<StudentRegistrationPortal.Models.StudentModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml"; ;
}


<div class="container-fluid mt-4">

    <!-- Page Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3 gap-3">

        <h4 class="fw-bold text-primary w-50">🎓 Student Management</h4>


        <div class="d-flex flex-column flex-md-row gap-3 w-100 justify-content-start justify-content-md-end align-items-stretch">





            <!-- Search Form -->
            <form method="get"
                  asp-area="Admin"
                  asp-controller="Home"
                  asp-action="Index"
                  class="w-70 w-md-auto"
                  style="min-width: 260px;">

                <div class="input-group">
                    <input type="text"
                           name="searchTerm"
                           class="form-control"
                           placeholder="Search by name, email, course..."
                           value="@Context.Request.Query["searchTerm"]" />

                    <button type="submit" class="btn btn-primary">
                        Search
                    </button>
                </div>
            </form>

            @* excel import button *@
            <form asp-action="ImportExcel"
                  method="post"
                  enctype="multipart/form-data"
                  class="w-90 w-md-auto"
                  style="min-width: 260px;">

                <div class="input-group">
                    <input class="form-control"
                           type="file"
                           name="excelFile"
                           accept=".xlsx" />

                    <button class="btn btn-primary" type="submit">
                        Import Excel
                    </button>
                </div>
            </form>





            <!-- Add Student Button (PURE LINK) -->
            <a href="/Admin/Home/Create"
               class="btn btn-success align-self-stretch d-flex align-items-center">
                + Add Student
            </a>



        </div>
    </div>





    <!-- Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Parents</th>
                            <th>Course</th>
                            <th>CGPA</th>
                            <th>Semester</th>
                            <th>Year</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.StudentName</td>
                                    <td>@item.Student_Email</td>
                                    <td>
                                        <small class="d-block">Father: @item.FatherName</small>
                                        <small class="d-block">Mother: @item.MotherName</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @item.Course
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">
                                            @item.CGPA
                                        </span>
                                    </td>
                                    <td>@item.Semester</td>
                                    <td>@item.Admission_Year</td>
                                    <td class="text-center">
                                        <a asp-area="Admin"
                                           asp-controller="Home"
                                           asp-action="Update"
                                           asp-route-id="@item.id"
                                           class="btn btn-sm btn-outline-primary me-1">
                                            Edit
                                        </a>

                                        <form asp-area="Admin"
                                              asp-controller="Home"
                                              asp-action="Delete"
                                              asp-route-id="@item.id"
                                              method="post"
                                              style="display:inline;">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Are you sure you want to delete this student?');">
                                                Delete
                                            </button>
                                        </form>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    No students found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            

        </div>
    </div>
</div>
