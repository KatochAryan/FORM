@model StudentRegistrationPortal.Models.StudentModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Student";
}

@section Styles {
    <style>
        body {
            background: linear-gradient(120deg, #eef2f7, #f8f9fb);
            font-family: "Segoe UI", sans-serif;
        }

        /* ===== Card ===== */
        .form-card {
            max-width: 900px;
            margin: 6% auto;
            background: #ffffff;
            border-radius: 16px;
            padding: 35px 40px;
            box-shadow: 0 20px 45px rgba(0,0,0,0.08);
            animation: fadeIn 0.6s ease-in-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .form-title {
            text-align: center;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 6px;
        }

        .form-subtitle {
            text-align: center;
            color: #6b7280;
            margin-bottom: 30px;
            font-size: 14px;
        }

        /* ===== Sections ===== */
        .form-section {
            margin-bottom: 32px;
        }

            .form-section h4 {
                font-size: 16px;
                font-weight: 700;
                margin-bottom: 18px;
                color: #0d6efd;
                border-left: 4px solid #0d6efd;
                padding-left: 10px;
            }

        /* ===== Form Fields ===== */
        .form-group {
            margin-bottom: 18px;
        }

            .form-group label {
                font-size: 13px;
                font-weight: 600;
                margin-bottom: 6px;
                color: #374151;
                display: block;
            }

            .form-group input,
            .form-group select {
                width: 100%;
                height: 44px;
                padding: 10px 14px;
                border-radius: 8px;
                border: 1px solid #d1d5db;
                font-size: 14px;
                background: #fff;
                transition: 0.25s;
            }

                .form-group input:focus,
                .form-group select:focus {
                    border-color: #2563eb;
                    box-shadow: 0 0 0 3px rgba(37,99,235,0.15);
                    outline: none;
                }

        /* ===== Grid ===== */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 18px;
        }

        /* ===== Photo Upload ===== */
        .photo-section {
            text-align: center;
            margin-bottom: 35px;
        }

        .photo-box {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 2px dashed #cbd5e1;
            margin: auto;
            background: #f9fafb;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .photo-box img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: none;
            }

        .file-label {
            margin-top: 12px;
            display: inline-block;
            background: #2563eb;
            color: white;
            padding: 8px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
        }

            .file-label:hover {
                background: #1e40af;
            }

            .file-label input {
                display: none;
            }

        /* ===== Buttons ===== */
        .form-actions {
            text-align: center;
            margin-top: 35px;
        }

        .btn-primary {
            padding: 11px 34px;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            border: none;
            background: linear-gradient(135deg, #2563eb, #1e40af);
            color: #fff;
        }

        .btn-secondary {
            margin-left: 15px;
            color: #2563eb;
            font-weight: 600;
            text-decoration: none;
        }

        @@media (max-width: 768px) {
            .form-card {
                padding: 25px;
                margin-top: 10%;
            }
        }
    </style>
}

<div class="form-card">
    <h2 class="form-title">Add Student</h2>
    <p class="form-subtitle">Fill in the details below</p>

    <form asp-area="Admin" asp-controller="Home" asp-action="Create"
          method="post" enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <!-- Photo -->
        <div class="photo-section">
            <div class="photo-box">
                <img id="photoPreview" />
            </div>
            <label class="file-label">
                Upload Photo
                <input type="file" asp-for="Photo"
                       accept=".jpg,.jpeg,.png"
                       onchange="previewImage(this)" />
            </label>
        </div>

        <!-- Personal Information -->
        <div class="form-section">
            <h4>Personal Information</h4>

            <div class="form-group">
                <label>Student Name</label>
                <input asp-for="StudentName" required />
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label>Father Name</label>
                    <input asp-for="FatherName" required />
                </div>

                <div class="form-group">
                    <label>Mother Name</label>
                    <input asp-for="MotherName" required />
                </div>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Student_Email" type="email" required />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input asp-for="Password" type="password" required />
            </div>

            <div class="form-group">
                <label>Date of Birth</label>
                <input asp-for="Dob" id="dob" placeholder="DD/MM/YYYY" />
            </div>

            <div class="form-group">
                <label>Mobile Number</label>
                <input asp-for="Mobile" maxlength="10"
                       oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
            </div>
        </div>

        <!-- Academic Information -->
        <div class="form-section">
            <h4>Academic Information</h4>

            <div class="grid-2">
                <div class="form-group">
                    <label>Course</label>
                    <select asp-for="Course">
                        <option value="">Select</option>
                        <option>BCA</option>
                        <option>MCA</option>
                        <option>B.Tech</option>
                        <option>M.Tech</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Semester</label>
                    <select asp-for="Semester">
                        <option value="">Select</option>
                        <option>1</option>
                        <option>2</option>
                        <option>3</option>
                        <option>4</option>
                        <option>5</option>
                        <option>6</option>
                    </select>
                </div>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label>CGPA</label>
                    <input asp-for="CGPA" type="number" />
                </div>

                <div class="form-group">
                    <label>Admission Year</label>
                    <input asp-for="Admission_Year" />
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save</button>
            <a asp-action="Index" class="btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        flatpickr("#dob", {
            dateFormat: "d/m/Y",
            maxDate: "today",
            allowInput: true
        });

        function previewImage(input) {
            const img = document.getElementById("photoPreview");
            const reader = new FileReader();
            reader.onload = e => {
                img.src = e.target.result;
                img.style.display = "block";
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>
}
