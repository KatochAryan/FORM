@{
    Layout = "_Auth";
    ViewData["Title"] = "Login";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["Success"]
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger text-center">
        @ViewBag.Error
    </div>
}


<div class="d-flex align-items-center justify-content-center vh-100">


    <div class="login-wrapper">
        <div class="login-row">

            <!-- LEFT SIDE -->
            <div class="login-left">

                <button type="button"
                        class="big-option"
                        onclick="showForm('student')">
                    <i class="fa-solid fa-user-graduate"></i>
                    <span>Student Login</span>
                </button>

                <button type="button"
                        class="big-option"
                        onclick="showForm('admin')">
                    <i class="fa-solid fa-user-shield"></i>
                    <span>Admin Login</span>
                </button>


            </div>

            <!-- RIGHT SIDE -->
            <div class="login-right">

                <!-- Student Login -->
                <div id="studentForm" class="form-box active">
                    <h3>Student Login</h3>

                    <form asp-action="Login" asp-controller="StudentErp" method="post">
                        @Html.AntiForgeryToken()

                        <input class="form-control mb-3"
                               name="Email"
                               placeholder="Email" />

                        <input class="form-control mb-2"
                               type="password"
                               name="Password"
                               placeholder="Password" />

                        <input type="hidden" name="Role" value="Student" />

                        <button class="btn btn-primary w-100">Login</button>
                        <!-- Forgot / Register -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <a asp-controller="StudentErp"
                               asp-action="ForgotPassword"
                               class="forgot-link fw-semibold">
                                Forgot Password?
                            </a>

                            <a asp-controller="StudentErp"
                               asp-action="Create"
                               class="forgot-link fw-semibold">
                                New User? Register
                            </a>
                        </div>

                    </form>

                </div>


                <!-- Admin Login -->
                <div id="adminForm" class="form-box">
                    <h3>Admin Login</h3>

                    <form asp-action="Login" asp-controller="StudentErp" method="post">
                        @Html.AntiForgeryToken()

                        <input class="form-control mb-3"
                               name="Email"
                               placeholder="Admin Email" />

                        <input class="form-control mb-3"
                               type="password"
                               name="Password"
                               placeholder="Password" />

                        <input type="hidden" name="Role" value="Admin" />

                        <button class="btn btn-primary w-100">Login</button>

                    </form>
                </div>


            </div>


        </div>
    </div>
</div>

<script>
    function showForm(type) {
        // Hide all forms
        document.querySelectorAll('.form-box')
            .forEach(f => f.classList.remove('active'));

        // Show selected form
        document.getElementById(type + 'Form')
            .classList.add('active');

        // Button active state
        document.querySelectorAll('.big-option')
            .forEach(b => b.classList.remove('active'));

        if (type === 'student') {
            document.querySelectorAll('.big-option')[0].classList.add('active');
        } else {
            document.querySelectorAll('.big-option')[1].classList.add('active');
        }

        //  MOBILE: show right panel
        document.querySelector('.login-right').classList.add('active');
    }
</script>


