@model Form.Models.EditModel

@{
    ViewData["Title"] = "Edit Student";
}



@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}
<style>




    .Containerx {
        display: flex;
        flex-direction: row;
        justify-content: center;
    }



    .FormContainer {
        box-shadow: 14px 11px 8px rgba(0, 0, 0, 0.1);
        width: 67%;
        border: 0.5px solid #928b8b;
    }

    .form-card {
        padding-left: 3%;
        padding-top: 3%;
        padding-bottom: 35px;
    }

    .heading {
        background-color: #007eff;
        color: white;
        height: 51px;
    }
</style>


<div class="Containerx">

    <div class="FormContainer">
        <div class="heading">
            <h3 class="text-center">Update Profile</h3>
        </div>
        <div id="qualificationTemplate" class="d-none">
            <div class="border p-3 mb-3 rounded qualification-item">
                <input type="hidden" name="Qualifications[__index__].Qual_id" value="0" />

                <div class="row mb-3">
                    <div class="col-2">
                        <label class="form-label">Stream</label>
                    </div>
                    <div class="col-8">
                        <select name="Qualifications[__index__].Stream" class="form-control">
                            <option value="">-- Select --</option>
                            <option value="10th Marksheet">10th Marksheet</option>
                            <option value="12th Marksheet">12th Marksheet</option>
                            <option value="Graduation">Graduation</option>
                        </select>

                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-2">
                        <label class="form-label">Remark</label>
                    </div>
                    <div class="col-8">
                        <input name="Qualifications[__index__].Remark" class="form-control" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-2">
                        <label class="form-label">Document</label>
                    </div>
                    <div class="col-8">
                        <input type="file"
                               name="Qualifications[__index__].File"
                               class="form-control" />
                    </div>
                </div>

                <button type="button"
                        class="btn btn-danger btn-sm"
                        onclick="this.closest('.qualification-item').remove()">
                    Remove
                </button>
            </div>
        </div>

        <div class="form-card">
            <form asp-action="Edit"
                  method="post"
                  enctype="multipart/form-data"
                  id="editForm">

                <input type="hidden" asp-for="Id" />

                <!-- ================= BASIC DETAILS ================= -->
                <div class="row mb-3">
                    <div class="col-2">
                        <label asp-for="FirstName" class="form-label"></label>
                    </div>
                    <div class=" col-8">
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                </div>


                <div class="row mb-3">
                    <div class="col-2">
                        <label asp-for="LastName" class="form-label"></label>
                    </div>
                    <div class="col-8">
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-2">
                        <label asp-for="Dob" class="form-label"></label>
                    </div>
                    <div class="col-8">
                        <input asp-for="Dob" type="date" class="form-control" />
                        <span asp-validation-for="Dob" class="text-danger"></span>

                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-2">
                        <label asp-for="Gender" class="form-label"></label>
                    </div>
                    <div class="col-9">
                        <div class="form-check form-check-inline">
                            <input asp-for="Gender" class="form-check-input" type="radio" value="Male" />
                            <label class="form-check-label">Male</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input asp-for="Gender" class="form-check-input" type="radio" value="Female" />
                            <label class="form-check-label">Female</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input asp-for="Gender" class="form-check-input" type="radio" value="Other" />
                            <label class="form-check-label">Other</label>
                        </div>
                        <br />
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-2">
                        <label asp-for="Category" class="form-label"></label>
                    </div>
                    <div class="col-7">
                        <select asp-for="Category" class="form-select">
                            <option value="">-- Select --</option>
                            <option>General</option>
                            <option>OBC</option>
                            <option>SC/ST</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>


                </div>

                <!-- ================= STATUS ================= -->
                @* <div class="mb-3 statusx">
                <label asp-for="Status" class="form-label"></label>
                <input asp-for="Status" class="form-control" disabled />
                <input type="hidden" asp-for="Status" />
                <small class="text-muted">Status cannot be changed</small>
            </div> *@

                <!-- ================= PHOTO ================= -->
                <div class="row mb-3">
                    <div class="col-2">
                        <label class="form-label">Current Photo</label><br />
                    </div>
                    <div class="col-8">
                        <img id="photoPreview"
                             src="@(string.IsNullOrEmpty(Model.Photo) ? "/images/no-image.png" : Model.Photo)"
                             width="120"
                             class="border rounded mb-2" />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-2">
                        <label class="form-label">Change Photo (optional)</label>
                    </div>
                    <div class="col-8">
                        <input asp-for="PhotoFile"
                               type="file"
                               class="form-control"
                               accept="image/*"
                               onchange="previewPhoto(this)" />
                    </div>
                </div>

                <!-- ================= QUALIFICATIONS ================= -->
                <h4>Qualifications</h4>
                <button type="button"
                        class="btn btn-success mb-3"
                        onclick="addQualification()">
                     Add Qualification
                </button>



                @for (int i = 0; i < Model.Qualifications.Count; i++)
                {

                    <div class="border p-3 mb-3 rounded qualification-item">

                        <input type="hidden" asp-for="Qualifications[@i].Qual_id" />
                        <input type="hidden" asp-for="Qualifications[@i].FilePath" />

                        <div class="row mb-3">
                            <div class="col-2">
                                <label class="form-label">Stream</label>
                            </div>
                            <div class="col-8">
                                <select asp-for="Qualifications[@i].Stream" class="form-control">
                                    <option value="">-- Select --</option>
                                    <option value="10th Marksheet">10th Marksheet</option>
                                    <option value="12th Marksheet">12th Marksheet</option>
                                    <option value="Graduation">Graduation</option>
                                </select>




                            </div>

                        </div>

                        <div class="row mb-3">
                            <div class="col-2">
                                <label class="form-label">Remark</label>
                            </div>
                            <div class="col-8">
                                <input asp-for="Qualifications[@i].Remark" class="form-control" />
                                <span asp-validation-for="Qualifications[@i].Remark" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-2">
                                <label class="form-label">Existing Document</label>
                            </div>

                            <div class="col-8">
                                @if (!string.IsNullOrWhiteSpace(Model.Qualifications[i].FilePath))
                                {
                                    <a id="docLink_@i"
                                       href="@Url.Content(Model.Qualifications[i].FilePath)"
                                       target="_blank"
                                       class="btn btn-primary btn-sm">
                                        View Document
                                    </a>

                                    <button type="button"
                                            class="btn btn-danger btn-sm ms-2"
                                            onclick="deleteDocument(@i)">
                                        Delete
                                    </button>

                                    <input type="hidden"
                                           asp-for="Qualifications[@i].DeleteDocument"
                                           id="deleteFlag_@i" />
                                }
                                else
                                {
                                    <span class="text-muted">No document uploaded</span>
                                }

                                <div id="docInfo_@i" class="text-success small mt-1"></div>
                            </div>
                        </div>


                        <div class="row mb-3">
                            <div class="col-2">
                                <label class="form-label">Replace Document (optional)</label>
                            </div>
                            <div class="col-8">
                                <input asp-for="Qualifications[@i].File"
                                       type="file"
                                       class="form-control"
                                       onchange="previewDocument(this, @i)" />
                            </div>
                        </div>
                        <!-- DELETE QUALIFICATION -->
                        <input type="hidden"
                               asp-for="Qualifications[@i].DeleteQualification"
                               id="deleteQual_@i" />

                        <button type="button"
                                class="btn btn-danger btn-sm"
                                onclick="deleteQualification(@i)">
                             Delete Qualification
                        </button>

                    </div>
                }
                <!-- ================= SUBMIT ================= -->
                <button type="submit" class="btn btn-primary">Update</button>
                <a asp-action="Create" class="btn btn-secondary">Back</a>
            </form>
        </div>


    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function previewPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById("photoPreview").src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function previewDocument(input, index) {
            if (input.files && input.files[0]) {
                document.getElementById("docInfo_" + index).innerText =
                    "New file selected: " + input.files[0].name;

                const oldLink = document.getElementById("docLink_" + index);
                if (oldLink) {
                    oldLink.style.pointerEvents = "none";
                    oldLink.style.opacity = "0.5";
                    oldLink.innerText = "Old document (will be replaced)";
                }
            }
        }
    </script>

    <script>
        document.getElementById("editForm").addEventListener("submit", function (e) {

            const inputs = this.querySelectorAll(
                "input[type='text'], input[type='date'], select, textarea"
            );

            let hasValue = false;

            inputs.forEach(el => {
                if (el.value && el.value.trim() !== "") {
                    hasValue = true;
                }
            });

            // Check radio buttons (Gender)
            const radios = this.querySelectorAll("input[type='radio']");
            radios.forEach(r => {
                if (r.checked) {
                    hasValue = true;
                }
            });

            // Check file inputs
            const files = this.querySelectorAll("input[type='file']");
            files.forEach(f => {
                if (f.files.length > 0) {
                    hasValue = true;
                }
            });

            if (!hasValue) {
                e.preventDefault(); // stop form submit
                alert("⚠️ Please fill at least one field before updating.");
            }
        });
    </script>

    <script>
        function deleteDocument(index) {
            if (!confirm("Are you sure you want to delete this document?")) return;

            document.getElementById("deleteFlag_" + index).value = "true";

            const link = document.getElementById("docLink_" + index);
            if (link) {
                link.remove();
            }

            document.getElementById("docInfo_" + index).innerText =
                "Document will be deleted after update.";
        }
    </script>
    <script>
        let qualIndex = @Model.Qualifications.Count;

        function addQualification() {
            const template = document
                .getElementById("qualificationTemplate")
                .innerHTML
                .replace(/__index__/g, qualIndex);

            document
                .querySelector("h4 + button")
                .insertAdjacentHTML("afterend", template);

            qualIndex++;
        }
    </script>

    <script>
        function deleteQualification(index) {
            if (!confirm("Are you sure you want to delete this qualification?")) return;

            // set delete flag
            document.getElementById("deleteQual_" + index).value = "true";

            // hide qualification UI
            document.getElementById("deleteQual_" + index)
                .closest(".qualification-item")
                .style.display = "none";
        }
    </script>




}
